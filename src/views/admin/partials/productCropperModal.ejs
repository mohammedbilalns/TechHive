<div id="cropperModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
  <div class="bg-white rounded-lg p-4 sm:p-6 max-w-2xl w-full mx-4 max-h-[90vh] flex flex-col">
    <div class="flex justify-between items-center mb-4 shrink-0">
      <h3 class="text-lg font-semibold">Crop Image</h3>
      <button type="button" onclick="closeCropper()" class="text-gray-500 hover:text-gray-700">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="w-full max-h-[60vh] mb-4 overflow-hidden flex justify-center bg-gray-50 shrink-0">
      <img id="cropperImage" src="#" style="max-width: 100%; max-height: 60vh; display: block;">
    </div>
    <div class="flex justify-end gap-3 shrink-0">
      <button type="button" onclick="closeCropper()"
        class="px-4 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300">Cancel</button>
      <button type="button" class="apply-button px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600"
        onclick="applyCrop()">Apply</button>
    </div>
  </div>
</div>
