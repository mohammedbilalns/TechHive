<div id="<%= modalId %>" class="fixed inset-0 z-[60] bg-gray-600 bg-opacity-50 hidden items-center justify-center p-4 overflow-y-auto">
  <div class="relative z-[70] bg-white rounded-lg shadow-xl p-6 m-4 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-semibold text-gray-800"><%= title %></h2>
      <button onclick="<%= closeHandler %>()" class="text-gray-600 hover:text-gray-900">
        <i class="fas fa-times"></i>
      </button>
    </div>

    <form id="<%= formId %>">
      <%- include('./addressFormFields', { formType, includeAddressId }) %>
      <div class="flex justify-end space-x-4 mt-4">
        <button type="button" onclick="<%= closeHandler %>()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">
          Cancel
        </button>
        <button type="button" onclick="<%= submitHandler %>()" class="bg-primary-accent text-white px-4 py-2 rounded-lg hover:bg-primary-accent/90">
          <%= submitLabel %>
        </button>
      </div>
    </form>
  </div>
</div>
