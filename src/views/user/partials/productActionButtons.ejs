<% if (showActions) { %>
  <div class="<%= containerClass %>">
    <% if (product.stock > 0) { %>
      <button onclick="addToCart('<%= product._id %>')" class="<%= addToCartClass %>" data-loading-variant="icon">
        <svg xmlns="http://www.w3.org/2000/svg" class="<%= cartIconClass %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
      </button>
    <% } %>

    <% if (wishlistItems.some(id => id.equals(product._id))) { %>
      <button onclick="removeFromWishlist('<%= product._id %>')" class="<%= removeFromWishlistClass %>" data-loading-variant="icon">
        <svg xmlns="http://www.w3.org/2000/svg" class="<%= wishlistIconClass %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </button>
    <% } else { %>
      <button onclick="addToWishlist('<%= product._id %>')" class="<%= addToWishlistClass %>" data-loading-variant="icon">
        <svg xmlns="http://www.w3.org/2000/svg" class="<%= wishlistIconClass %>" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </button>
    <% } %>
  </div>
<% } %>

<% if (showOutOfStockText && product.stock <= 0) { %>
  <p class="<%= outOfStockClass %>">Out of Stock</p>
<% } %>
