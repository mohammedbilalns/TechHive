<%- include('../../partials/authheader.ejs') %>
  <main class="min-h-[calc(100vh-64px)] flex justify-center items-center p-4">
    <div
      class="bg-white rounded-2xl shadow-2xl flex flex-col lg:flex-row overflow-hidden max-w-4xl w-full border border-gray-100">
      <!-- Image Section -->
      <div
        class="bg-gradient-to-br from-[#DA0037] to-[#ff1744] p-8 hidden sm:flex flex-col justify-center items-center lg:w-1/2 relative overflow-hidden">
        <div
          class="absolute inset-0 bg-black opacity-5 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white/10 via-transparent to-transparent">
        </div>
        <img alt="Login Illustration" src="/images/login2.png"
          class="w-4/5 h-auto object-contain drop-shadow-2xl relative z-10" />
        <div class="text-center mt-8 relative z-10">
          <h2 class="text-2xl font-bold text-white mb-2">Welcome Back!</h2>
          <p class="text-white/90">Sign in to continue your shopping journey</p>
        </div>
      </div>
      <!-- Form Section -->
      <div class="bg-gradient-to-br from-gray-50 to-white p-6 md:p-12 flex-1">
        <form action="/auth/google">
          <button type="submit"
            class="flex border-2 border-gray-200 items-center justify-center rounded-lg py-3 mb-6 bg-white text-gray-700 w-full hover:bg-gray-50 hover:border-gray-300 hover:shadow-md transition-all duration-300 font-medium">
            <img alt="Google logo" src="/images/google.svg" class="mr-3 w-5 h-5" />
            Continue with Google
          </button>
        </form>
        <form id="userlogin" method="post" action="/auth/login">
          <p
            class="text-3xl font-bold text-gray-800 mb-2 bg-gradient-to-r from-gray-800 to-gray-600 bg-clip-text text-transparent">
            Log in to TechHive</p>
          <p class="text-gray-500 mb-6 text-sm">Enter your details below</p>

          <div class="relative mb-4">
            <div class="relative">
              <span class="absolute inset-y-0 left-3 flex items-center text-[#DA0037]">
                <i class="fas fa-envelope"></i>
              </span>
              <input type="text" name="email" id="email" placeholder="Email"
                class="border-2 border-gray-200 w-full pl-10 pr-3 py-2 rounded-lg focus:border-[#DA0037] focus:ring-2 focus:ring-[#DA0037]/20 transition-all duration-300 bg-white" />
            </div>
            <p class="text-red-500 text-sm mt-1 min-h-[1.25rem]" id="emailError"></p>
          </div>

          <div class="relative mb-6">
            <div class="relative">
              <span class="absolute inset-y-0 left-3 flex items-center text-[#DA0037]">
                <i class="fas fa-lock"></i>
              </span>
              <input type="password" name="password" id="password" placeholder="Password"
                class="border-2 border-gray-200 w-full pl-10 pr-10 py-2 rounded-lg focus:border-[#DA0037] focus:ring-2 focus:ring-[#DA0037]/20 transition-all duration-300 bg-white" />
              <span
                class="absolute inset-y-0 right-3 flex items-center cursor-pointer text-gray-600 hover:text-[#DA0037] transition-colors"
                id="togglePassword">
                <i class="fas fa-eye"></i>
              </span>
            </div>
            <p class="text-red-500 text-sm mt-1 min-h-[1.25rem]" id="passwordError"></p>
          </div>

          <div class="flex flex-col items-center">
            <button type="submit" id="loginButton"
              class="w-full py-3 mb-3 text-white font-semibold bg-gradient-to-r from-[#DA0037] to-[#ff1744] hover:shadow-lg hover:scale-[1.02] rounded-lg flex items-center justify-center transition-all duration-300">
              <span>Log In</span>
              <div id="loginLoader" class="hidden ml-2">
                <div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
              </div>
            </button>
            <button type="button" id="guestLoginButton"
              class="w-full py-3 mb-3 text-[#DA0037] font-semibold bg-white border-2 border-dashed border-[#DA0037]/40 hover:border-[#DA0037] hover:bg-[#DA0037]/5 rounded-lg flex items-center justify-center transition-all duration-300">
              <span>Try as Guest</span>
              <div id="guestLoader" class="hidden ml-2">
                <div class="w-5 h-5 border-2 border-[#DA0037] border-t-transparent rounded-full animate-spin"></div>
              </div>
            </button>
         
            <a href="/auth/forgot-password" class="text-sm text-[#DA0037] hover:text-[#ff1744] mb-4 transition-colors">Forgot
              Password?</a>
            <div class="text-sm text-gray-600">Don't have an account? <a href="/auth/signup"
                class="text-[#DA0037] hover:text-[#ff1744] font-semibold transition-colors">Sign Up</a></div>
          </div>
        </form>
      </div>
    </div>
  </main>



  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/toastify-js" defer></script>
  <script src="/js/auth/login.js" type="module"></script>
  </body>

  </html>
