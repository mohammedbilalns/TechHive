  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "tailwind": "npx tailwindcss -i ./src/static/styles/styles.css -o ./src/static/tailwind/output.css --watch ",
    "build:css": "tailwindcss -i ./src/static/styles/styles.css -o ./src/static/tailwind/output.css --minify",
    "dev:server": "node --inspect --watch --env-file=.env ./src/server.js",
    "lint": "eslint --fix --ext .js .",
    "lint:fix": "eslint --fix --ext .js . --fix",
    "dev": "concurrently 'npm run tailwind' 'npm run dev:server'",
    "start": "node --env-file=.env ./src/server.js",
    "start:prod": "npm run build:css && npm run start"
  },
