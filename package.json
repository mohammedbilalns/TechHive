{
  "name": "techhive",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "tailwind": "tailwindcss -i ./src/static/styles/styles.css -o ./src/static/tailwind/output.css --watch",
    "build:css": "tailwindcss -i ./src/static/styles/styles.css -o ./src/static/tailwind/output.css --minify",
    "dev:server": "nodemon",
    "lint": "eslint --fix --ext .js .",
    "lint:fix": "eslint --fix --ext .js . --fix",
    "dev": "concurrently \"pnpm run tailwind\" \"pnpm run dev:server\"",
    "start": "node --env-file=.env ./src/server.js",
    "start:prod": "pnpm run build:css && pnpm run start",
    "format": "prettier --write ."
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "dependencies": {
    "@getbrevo/brevo": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "ejs": "^4.0.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "mongoose": "^8.8.2",
    "multer": "^2.0.1",
    "nanoid": "^5.0.9",
    "nocache": "^4.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.15.2",
    "razorpay": "^2.9.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^10.0.1",
    "nodemon": "^3.1.14",
    "prettier": "3.8.3",
    "tailwindcss": "^3.4.15"
  }
}
